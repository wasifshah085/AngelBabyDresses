# ===========================================
# PRODUCTION ENVIRONMENT CONFIGURATION (Vercel)
# ===========================================
# Set these as Environment Variables in Vercel Dashboard

NODE_ENV=production

# Frontend URL
CLIENT_URL=https://angelbabydresses.com

# ===========================================
# MongoDB Atlas
# ===========================================
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/angel-baby-dresses?retryWrites=true&w=majority

# ===========================================
# AUTHENTICATION
# ===========================================
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_A_STRONG_SECRET_KEY_HERE
JWT_EXPIRE=30d

# ===========================================
# IMAGEKIT (Image Storage - free at imagekit.io)
# ===========================================
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# ===========================================
# EMAIL (SMTP)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@angelbabydresses.com
FROM_NAME=Angel Baby Dresses
